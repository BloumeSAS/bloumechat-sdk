{
    "name": "bloumechat",
    "version": "2.1.0",
    "description": "Official JavaScript/TypeScript SDK for BloumeChat — build bots, automations and integrations with a strongly-typed, Discord-like API.",
    "main": "./dist/index.js",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "sideEffects": false,
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.js"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsup index.ts --format cjs,esm --dts --clean",
        "dev": "tsup index.ts --format cjs,esm --watch --dts",
        "typecheck": "tsc --noEmit",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "release": "npm run build && npm version patch && npm publish",
        "publish-sdk": "npm run build && npm publish",
        "prepublishOnly": "npm run typecheck && npm run lint && npm run format:check && npm run test && npm run build",
        "version": "node scripts/sync-readme-version.js && git add README.md",
        "check:readme-version": "node scripts/sync-readme-version.js --check"
    },
    "keywords": [
        "bloumechat",
        "sdk",
        "chat",
        "api",
        "bot",
        "typescript",
        "websocket",
        "realtime",
        "voice",
        "webrtc"
    ],
    "author": {
        "name": "BloumeSAS",
        "url": "https://bloume.fr"
    },
    "license": "ISC",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/BloumeSAS/bloumechat-sdk.git"
    },
    "homepage": "https://dev.bloume.chat",
    "bugs": {
        "url": "https://github.com/BloumeSAS/bloumechat-sdk/issues"
    },
    "engines": {
        "node": ">=20"
    },
    "dependencies": {
        "opusscript": "^0.0.8",
        "prism-media": "^1.3.5",
        "socket.io-client": "^4.8.3",
        "werift": "^0.23.0"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/node": "^20.14.0",
        "@vitest/coverage-v8": "^4.1.9",
        "eslint": "^10.6.0",
        "eslint-config-prettier": "^10.1.8",
        "globals": "^17.7.0",
        "prettier": "^3.9.4",
        "tsup": "^8.0.2",
        "typescript": "^5.3.3",
        "typescript-eslint": "^8.62.1",
        "vitest": "^4.1.9"
    }
}
